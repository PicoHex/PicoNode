<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <IsPackable>true</IsPackable>
    <IsAotCompatible>true</IsAotCompatible>
    <IsTrimmable>true</IsTrimmable>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageId>PicoNode.Web</PackageId>
    <Description>Web application middleware framework for PicoNode. Provides WebApp builder, RadixTree router, middleware pipeline (CORS, compression, caching, security headers, static files), Server-Sent Events, and multipart form data parsing.</Description>
    <PackageTags>PicoHex;PicoNode;AOT;Web;Middleware;Router;CORS;SSE;Networking</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="PicoNode.Web.Tests" />
    <InternalsVisibleTo Include="PicoNode.Tests" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="PicoDI.Abs" />
    <PackageReference Include="PicoLog.Abs" />
    <PackageReference Include="PicoCfg.Abs" />
  </ItemGroup>

  <ItemGroup Condition="'$(UseProjectReferences)' == 'true'">
    <ProjectReference Include="..\..\Network\PicoNode.Abs\PicoNode.Abs.csproj" />
    <ProjectReference Include="..\PicoNode.Web.Session.Abs\PicoNode.Web.Session.Abs.csproj" />
    <ProjectReference Include="..\..\Http\PicoNode.Http\PicoNode.Http.csproj" />
  </ItemGroup>

  <ItemGroup Condition="'$(UseProjectReferences)' != 'true'">
    <PackageReference Include="PicoNode.Abs" />
    <PackageReference Include="PicoNode.Web.Session.Abs" />
    <PackageReference Include="PicoNode.Http" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\..\README.md" Pack="true" PackagePath="" Visible="false" />
  </ItemGroup>
</Project>
